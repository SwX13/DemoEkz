<Window x:Class="DemoEkz.Pages.DemoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DemoEkz.Pages"
        mc:Ignorable="d"
        Title="DemoWindow" Height="760" Width="980">

    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="42"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Padding" Value="10 0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="Height" Value="42"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Padding" Value="10 0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Border Background="White" CornerRadius="30" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Padding="30">
            <Border.Effect>
                <DropShadowEffect BlurRadius="30" Opacity="0.18"/>
            </Border.Effect>

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                        <!-- title -->
                        <RowDefinition Height="*"/>
                        <!-- base -->
                        <RowDefinition Height="auto"/>
                        <!-- buttons -->
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0">
                        <TextBlock Text="Авторизация пользователя" HorizontalAlignment="Center" FontSize="30" FontWeight="Bold"/>
                        <TextBlock Text="Введите логин и пароль, затем введите капчу" HorizontalAlignment="Center" FontSize="15" Foreground="DarkGray"/>
                    </StackPanel>
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="WhiteSmoke" CornerRadius="30" Padding="24" VerticalAlignment="Stretch">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Данные для входа" FontWeight="Bold" FontSize="25" Margin="0 0 0 24"/>
                                <TextBlock Text="Логин" FontSize="20" FontWeight="SemiBold" Margin="0 0 0 20"/>
                                <TextBox x:Name="loginTextBox" Margin="0 0 0 20" Height="50"/>
                                <TextBlock Text="Пароль" FontSize="20" FontWeight="SemiBold" Margin="0 0 0 20"/>
                                <PasswordBox x:Name="passBox" Margin="0 0 0 20" Height="50"/>

                                <TextBlock Margin="0 100 0 0" Text="Поля логин и пароль обязательны для заполнения" Foreground="LightGray"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="2" Background="WhiteSmoke" CornerRadius="30">

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0">
                                    <TextBlock Text="Интерактивная капча" HorizontalAlignment="Center" FontSize="30" FontWeight="Bold"/>
                                    <TextBlock Text="Нажмите на фрагмент, затем нажмите на нужную ячейку итогового изображения" HorizontalAlignment="Center" FontSize="15" FontWeight="SemiBold" TextWrapping="Wrap" TextAlignment="Center" Foreground="Gray"/>
                                </StackPanel>

                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="24"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Ячейки" FontSize="20" TextAlignment="Center"/>

                                        <Viewbox Stretch="Uniform" MaxHeight="320" HorizontalAlignment="Center" VerticalAlignment="Top">
                                            <UniformGrid Rows="2" Columns="2" Width="200" Height="200">
                                                <Border x:Name="slot1" Background="Transparent" BorderThickness="1" BorderBrush="LightGray" MouseLeftButtonDown="Slot_Click">
                                                    <Grid>
                                                        <TextBlock Text="1" TextAlignment="Center" VerticalAlignment="Center" FontSize="25"/>
                                                        <Image x:Name="slotImage1" Stretch="Fill"/>
                                                    </Grid>
                                                </Border>
                                                <Border x:Name="slot2" Background="Transparent" BorderThickness="1" BorderBrush="LightGray" MouseLeftButtonDown="Slot_Click">
                                                    <Grid>
                                                        <TextBlock Text="2" TextAlignment="Center" VerticalAlignment="Center" FontSize="25"/>
                                                        <Image x:Name="slotImage2" Stretch="Fill"/>
                                                    </Grid>
                                                </Border>
                                                <Border x:Name="slot3" Background="Transparent" BorderThickness="1" BorderBrush="LightGray" MouseLeftButtonDown="Slot_Click">
                                                    <Grid>
                                                        <TextBlock Text="3" TextAlignment="Center" VerticalAlignment="Center" FontSize="25"/>
                                                        <Image x:Name="slotImage3" Stretch="Fill"/>
                                                    </Grid>
                                                </Border>
                                                <Border x:Name="slot4" Background="Transparent" BorderThickness="1" BorderBrush="LightGray" MouseLeftButtonDown="Slot_Click">
                                                    <Grid>
                                                        <TextBlock Text="4" TextAlignment="Center" VerticalAlignment="Center" FontSize="25"/>
                                                        <Image x:Name="slotImage4" Stretch="Fill"/>
                                                    </Grid>
                                                </Border>

                                            </UniformGrid>
                                        </Viewbox>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Фрагменты" FontSize="20" TextAlignment="Center"/>

                                        <Viewbox Stretch="Uniform" MaxHeight="320" HorizontalAlignment="Center" VerticalAlignment="Top">
                                            <UniformGrid Rows="2" Columns="2" Width="200" Height="200">
                                                <Border x:Name="part1" BorderThickness="1" BorderBrush="LightGray" MouseLeftButtonDown="Part_Click">
                                                    <Image x:Name="partImage1" Stretch="Fill"/>
                                                </Border>
                                                <Border x:Name="part2" BorderThickness="1" BorderBrush="LightGray" MouseLeftButtonDown="Part_Click" Opacity="10">
                                                        <Image x:Name="partImage2" Stretch="Fill"/>
                                                </Border>
                                                <Border x:Name="part3" BorderThickness="1" BorderBrush="LightGray" MouseLeftButtonDown="Part_Click">
                                                        <Image x:Name="partImage3" Stretch="Fill"/>
                                                </Border>
                                                <Border x:Name="part4" BorderThickness="1" BorderBrush="LightGray" MouseLeftButtonDown="Part_Click">
                                                        <Image x:Name="partImage4" Stretch="Fill"/>
                                                </Border>

                                            </UniformGrid>
                                        </Viewbox>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0 26 0 0">
                        <Button Content="Перемешать капчу" Background="LightGray" Margin="0 0 100 0" Height="30" Width="190" Click="Button_Click"/>
                        <Button Content="Войти" Background="BlueViolet" Foreground="White" Width="190" Click="AuthButton_Click"/>
                    </StackPanel>

                </Grid>

            </ScrollViewer>
        </Border>
    </Grid>
</Window>
