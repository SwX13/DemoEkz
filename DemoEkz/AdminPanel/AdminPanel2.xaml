<Window x:Class="DemoEkz.AdminPanel.AdminPanel2"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DemoEkz.AdminPanel"
        mc:Ignorable="d"
        Title="AdminPanel2" Height="450" Width="800">
    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="35"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="35"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>
    <Grid>
        <Border CornerRadius="30" Background="WhiteSmoke" Margin="20">
            <Border.Effect>
                <DropShadowEffect Opacity=".18" BlurRadius="30"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Text="Рабочий стол администратора" Foreground="Black" FontSize="20"  FontWeight="Bold" TextWrapping="Wrap" TextAlignment="Center"/>
                    <TextBlock Text="Добавление, изменение пользователей и снятие блокировки" Foreground="gray" FontSize="15"  FontWeight="SemiBold" TextWrapping="Wrap" TextAlignment="Center"/>
                </StackPanel>

                <Border Grid.Row="1" Background="LightGray" CornerRadius="10" Padding="10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Добваление пользователя" FontSize="20" HorizontalAlignment="Center"/>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="14"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="14"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="14"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="14"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Логин" FontSize="15" FontWeight="SemiBold"/>
                                <TextBox x:Name="loginBox"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Пароль" FontSize="15" FontWeight="SemiBold"/>
                                <TextBox x:Name="passBox"/>
                            </StackPanel>

                            <StackPanel Grid.Column="4">
                                <TextBlock Text="Роль" FontSize="15" FontWeight="SemiBold"/>
                                <ComboBox x:Name="comboBox">
                                    <ComboBoxItem Content="Администратор" Tag="1"/>
                                    <ComboBoxItem Content="Пользователь" Tag="2"/>
                                </ComboBox>
                            </StackPanel>

                            <Button Grid.Column="6" Content="Войти" Foreground="White" Background="Blue" Margin="0 20 0 0 " Click="AddUser_Click"/>
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Row="2" Background="LightGray" CornerRadius="10" Padding="10" Margin="0 10 0 0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Список пользователей" Foreground="Black" FontSize="15"  FontWeight="SemiBold" TextWrapping="Wrap" TextAlignment="Left"/>

                        <DataGrid Grid.Row="1" x:Name="dataGridUsers" CanUserAddRows="False" CanUserDeleteRows="False" AutoGenerateColumns="False" SelectionMode="Single" SelectionUnit="FullRow">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="auto"/>
                                <DataGridTextColumn Header="Login" Binding="{Binding Login}" Width="auto"/>
                                <DataGridTextColumn Header="Password" Binding="{Binding Password}" Width="auto"/>
                                <DataGridComboBoxColumn x:Name="datagridComboBox" Header="Roles"  SelectedValuePath="Id" DisplayMemberPath="Name" SelectedValueBinding="{Binding RoleID}" Width="auto"/>
                                <DataGridCheckBoxColumn Header="IsBloked" Binding="{Binding IsBlocked}" Width="auto"/>
                                <DataGridTextColumn Header="Fails" Binding="{Binding FailledAttemp}" Width="auto"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
                
                

                <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0 5 0 5">
                    <Button Content="Обновить таблицу" Background="LightGray" Foreground="Black" Margin="0 0 12 0" Width="130" Height="25" Click="RefreshTable_Click"/>
                    <Button Content="Сохранить изменения" Background="Green" Foreground="white" Margin="0 0 12 0" Width="220" Height="25" Click="SaveChanges_Click"/>
                    <Button Content="Снять блокировку" Background="DarkOrange" Foreground="white" Margin="0 0 12 0" Width="130" Height="25" Click="ClearBlock_Click"/>
                    <Button Content="Выйти" Background="Red" Foreground="white" Margin="0 0 12 0" Width="130" Height="25" Click="Exit_Click"/>
                </StackPanel>

            </Grid>
        </Border>
    </Grid>
</Window>
