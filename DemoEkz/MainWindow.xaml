<Window x:Class="DemoEkz.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DemoEkz"
        mc:Ignorable="d"
        Title="MainWindow" Height="760" Width="980">

    <Window.Resources>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="42"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Padding" Value="10 0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="Height" Value="42"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Padding" Value="10 0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16 0"/>
        </Style>

        <Style x:Key="CaptchaCellStyle" TargetType="Border">
            <Setter Property="BorderBrush" Value="#94A3B8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="ClipToBounds" Value="True"/>
        </Style>

        <Style x:Key="CaptchaPartStyle" TargetType="Border">
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="ClipToBounds" Value="True"/>
        </Style>

    </Window.Resources>

   
    <Grid Margin="20">
        <Frame x:Name="MainFrame">

        </Frame>
        <Border Background="White"
                CornerRadius="22"
                Padding="30"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch">

            <Border.Effect>
                <DropShadowEffect BlurRadius="25"
                                  ShadowDepth="0"
                                  Opacity="0.18"/>
            </Border.Effect>

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Заголовок -->
                    <StackPanel Grid.Row="0" Margin="0 0 0 24">
                        <TextBlock Text="Авторизация пользователя"
                                   FontSize="30"
                                   FontWeight="Bold"
                                   Foreground="#0F172A"
                                   HorizontalAlignment="Center"/>

                        <TextBlock Text="Введите логин и пароль, затем соберите капчу из фрагментов"
                                   FontSize="15"
                                   Foreground="#64748B"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   Margin="0 8 0 0"/>
                    </StackPanel>

                    <!-- Основная часть -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="28"/>
                            <ColumnDefinition Width="1.4*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Авторизация -->
                        <Border Grid.Column="0"
                                Background="#F8FAFC"
                                BorderBrush="#E2E8F0"
                                BorderThickness="1"
                                CornerRadius="18"
                                Padding="24"
                                VerticalAlignment="Stretch">

                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Данные для входа"
                                           FontSize="22"
                                           FontWeight="Bold"
                                           Foreground="#0F172A"
                                           Margin="0 0 0 24"/>

                                <TextBlock Text="Логин"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="#334155"
                                           Margin="0 0 0 7"/>

                                <TextBox x:Name="txtLogin"
                                         Margin="0 0 0 18"/>

                                <TextBlock Text="Пароль"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="#334155"
                                           Margin="0 0 0 7"/>

                                <PasswordBox x:Name="txtPassword"
                                             Margin="0 0 0 26"/>

                                <TextBlock Text="Поля логин и пароль обязательны для заполнения."
                                           Foreground="#64748B"
                                           FontSize="14"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <!-- Капча -->
                        <Border Grid.Column="2"
                                Background="#F8FAFC"
                                BorderBrush="#E2E8F0"
                                BorderThickness="1"
                                CornerRadius="18"
                                Padding="24"
                                VerticalAlignment="Stretch">

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0">
                                    <TextBlock Text="Интерактивная капча"
                                               FontSize="22"
                                               FontWeight="Bold"
                                               Foreground="#0F172A"
                                               HorizontalAlignment="Center"
                                               Margin="0 0 0 6"/>

                                    <TextBlock Text="Нажмите на фрагмент, затем нажмите на нужную ячейку итогового изображения"
                                               FontSize="14"
                                               Foreground="#64748B"
                                               TextAlignment="Center"
                                               TextWrapping="Wrap"
                                               HorizontalAlignment="Center"
                                               Margin="0 0 0 18"/>
                                </StackPanel>

                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1*"/>
                                        <ColumnDefinition Width="24"/>
                                        <ColumnDefinition Width="1*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Итоговое изображение -->
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Итоговое изображение"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="#334155"
                                                   HorizontalAlignment="Center"
                                                   Margin="0 0 0 8"/>

                                        <Viewbox Stretch="Uniform"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Top"
                                                 MaxHeight="320">
                                            <UniformGrid Rows="2"
                                                         Columns="2"
                                                         Width="280"
                                                         Height="280">

                                                <Border x:Name="slot1"
                                                        Style="{StaticResource CaptchaCellStyle}"
                                                        MouseLeftButtonDown="Slot_Click">
                                                    <Grid>
                                                        <TextBlock Text="1"
                                                                   Foreground="#CBD5E1"
                                                                   FontSize="24"
                                                                   FontWeight="Bold"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
                                                        <Image x:Name="slotImage1" Stretch="Fill"/>
                                                    </Grid>
                                                </Border>

                                                <Border x:Name="slot2"
                                                        Style="{StaticResource CaptchaCellStyle}"
                                                        MouseLeftButtonDown="Slot_Click">
                                                    <Grid>
                                                        <TextBlock Text="2"
                                                                   Foreground="#CBD5E1"
                                                                   FontSize="24"
                                                                   FontWeight="Bold"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
                                                        <Image x:Name="slotImage2" Stretch="Fill"/>
                                                    </Grid>
                                                </Border>

                                                <Border x:Name="slot3"
                                                        Style="{StaticResource CaptchaCellStyle}"
                                                        MouseLeftButtonDown="Slot_Click">
                                                    <Grid>
                                                        <TextBlock Text="3"
                                                                   Foreground="#CBD5E1"
                                                                   FontSize="24"
                                                                   FontWeight="Bold"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
                                                        <Image x:Name="slotImage3" Stretch="Fill"/>
                                                    </Grid>
                                                </Border>

                                                <Border x:Name="slot4"
                                                        Style="{StaticResource CaptchaCellStyle}"
                                                        MouseLeftButtonDown="Slot_Click">
                                                    <Grid>
                                                        <TextBlock Text="4"
                                                                   Foreground="#CBD5E1"
                                                                   FontSize="24"
                                                                   FontWeight="Bold"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
                                                        <Image x:Name="slotImage4" Stretch="Fill"/>
                                                    </Grid>
                                                </Border>

                                            </UniformGrid>
                                        </Viewbox>
                                    </StackPanel>

                                    <!-- Фрагменты -->
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Фрагменты"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="#334155"
                                                   HorizontalAlignment="Center"
                                                   Margin="0 0 0 8"/>

                                        <Viewbox Stretch="Uniform"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Top"
                                                 MaxHeight="320">
                                            <UniformGrid Rows="2"
                                                         Columns="2"
                                                         Width="280"
                                                         Height="280">

                                                <Border x:Name="part1"
                                                        Style="{StaticResource CaptchaPartStyle}"
                                                        MouseLeftButtonDown="Part_Click">
                                                    <Image x:Name="partImage1" Stretch="Fill"/>
                                                </Border>

                                                <Border x:Name="part2"
                                                        Style="{StaticResource CaptchaPartStyle}"
                                                        MouseLeftButtonDown="Part_Click">
                                                    <Image x:Name="partImage2" Stretch="Fill"/>
                                                </Border>

                                                <Border x:Name="part3"
                                                        Style="{StaticResource CaptchaPartStyle}"
                                                        MouseLeftButtonDown="Part_Click">
                                                    <Image x:Name="partImage3" Stretch="Fill"/>
                                                </Border>

                                                <Border x:Name="part4"
                                                        Style="{StaticResource CaptchaPartStyle}"
                                                        MouseLeftButtonDown="Part_Click">
                                                    <Image x:Name="partImage4" Stretch="Fill"/>
                                                </Border>

                                            </UniformGrid>
                                        </Viewbox>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- Кнопки -->
                    <StackPanel Grid.Row="2"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0 26 0 0">

                        <Button x:Name="btnResetCaptcha"
                                Content="Перемешать капчу"
                                Width="190"
                                Background="#E2E8F0"
                                Foreground="#0F172A"
                                Margin="0 0 14 0"
                                Click="btnResetCaptcha_Click"/>

                        <Button x:Name="btnLogin"
                                Content="Войти"
                                Width="190"
                                Background="#2563EB"
                                Foreground="White"
                                Click="btnLogin_Click"/>

                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
